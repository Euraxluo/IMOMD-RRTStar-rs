        given-names: Yingwen
      - family-names: Lee
        given-names: Dongmyeong
      - family-names: Desaraju
        given-names: Vishnu R.
      - family-names: Grizzle
        given-names: Jessy W.
    title: "Informable Multi-Objective and Multi-Directional RRT* System for Robot Path Planning"
    year: 2022
    doi: "10.48550/arXiv.2205.14853"
    url: "https://arxiv.org/abs/2205.14853"
    notes: "ICRA 2023; original C++ implementation by UMich Biped Lab"
